# ─────────────────────────────────────────────
#  SABOREO — Variables de entorno
#  Copia este archivo como .env y completa los valores
#  cp .env.example .env
# ─────────────────────────────────────────────

# ── Base de datos ─────────────────────────────
POSTGRES_DB=saboreo
POSTGRES_USER=saboreo
POSTGRES_PASSWORD=cambia_esta_contraseña

# ── Backend ───────────────────────────────────
PORT=9021
DATABASE_URL=postgresql://saboreo:cambia_esta_contraseña@postgres:5432/saboreo

# URL pública donde corre el frontend (sin barra final)
FRONTEND_URL=http://localhost:9020

# Clave secreta para firmar JWT — genera una con: openssl rand -hex 32
JWT_SECRET=cambia_este_secreto

# ── Anthropic / Claude (IA de resultados) ─────
# Obtén tu clave en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Frontend ──────────────────────────────────
# URL pública del backend (sin barra final)
VITE_API_URL=http://localhost:9021
